# ─────────────────────────────────────────────────────────────────────────────
# MONENLET API — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# ─────────────────────────────────────────────────────────────────────────────

# Port d'écoute du serveur (défaut : 3000)
PORT=3000

# URL publique de l'API (utilisée dans la doc Swagger)
API_URL=http://localhost:3000

# Environnement : development | production | test
NODE_ENV=development
